###> CONFIGURAR TODAS ESTAS VARIABLES EN RAILWAY ###

APP_ENV=prod
APP_DEBUG=0

# Generar con: openssl rand -hex 32
APP_SECRET=REEMPLAZAR_CON_32_BYTES_HEX

# PostgreSQL — Railway lo provee automáticamente si agregás el plugin de Postgres
# Formato: postgresql://USER:PASS@HOST:PORT/DBNAME?serverVersion=16&charset=utf8
DATABASE_URL=postgresql://usuario:contrasena@host:5432/railway?serverVersion=16&charset=utf8

# JWT Keys — generar con:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:4096
#   openssl pkey -in private.pem -pubout -out public.pem
#   cat private.pem | base64 | tr -d '\n'   → pegar en JWT_PRIVATE_KEY_BASE64
#   cat public.pem  | base64 | tr -d '\n'   → pegar en JWT_PUBLIC_KEY_BASE64
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=REEMPLAZAR_CON_PASSPHRASE_SEGURA
JWT_PRIVATE_KEY_BASE64=PEGAR_AQUI_EL_BASE64_DEL_PRIVATE_PEM
JWT_PUBLIC_KEY_BASE64=PEGAR_AQUI_EL_BASE64_DEL_PUBLIC_PEM

# CORS — dominio del frontend en Vercel (sin barra final)
CORS_ALLOW_ORIGIN=^https://adelantos-app\.vercel\.app$

# Frontend URL — para links en emails
APP_FRONTEND_URL=https://adelantos-app.vercel.app

# Email (Resend — https://resend.com, plan gratuito: 3000 emails/mes)
MAILER_DSN=smtp://resend:TU_API_KEY_DE_RESEND@smtp.resend.com:465
MAILER_FROM_EMAIL=adelantos@enviopack.com
MAILER_FROM_NAME=Enviopack Adelantos

# Storage S3 / Cloudflare R2 para PDFs de facturas
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=adelantos-archivos
AWS_REGION=us-east-1
# Si usás Cloudflare R2 en vez de AWS:
# R2_ENDPOINT=https://TU_ACCOUNT_ID.r2.cloudflarestorage.com
